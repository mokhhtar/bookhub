rules_version = '2';

// BookHub Firestore security rules — the ONLY authorization layer
// (client-side Firebase, no backend intermediary). Paste into:
// Firebase Console → Firestore Database → Rules. Keep this file the
// source of truth; the console copy must always match it.
//
// Owner decisions baked in (2026-07-10):
//  - Email/password auth.
//  - Comments are PRE-MODERATED: created as approved=false, publicly
//    readable only once an admin flips approved=true.
//  - Recommendations v1: one vote per user per book (doc id == uid).
//  - Comment/review creation requires a VERIFIED email
//    (request.auth.token.email_verified). Google sign-ins are verified by
//    Google; email/password users must confirm via the link BookHub sends
//    on sign-up. Likes/recs/library are intentionally NOT gated on this.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin ────────────────────────────────────────────────
    // Replace with your own account's UID (Console → Authentication →
    // Users → copy UID) BEFORE publishing the rules.
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "REPLACE_WITH_ADMIN_UID";
    }

    function signedIn() {
      return request.auth != null;
    }

    // ── User profiles ────────────────────────────────────────
    // users/{uid}: {displayName, createdAt}
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid
        // displayName is shown next to comments — cap it and require a string.
        && (!(request.method in ["create", "update"])
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() >= 2
                && request.resource.data.displayName.size() <= 40));

      // ── Synced favorites (My Library) ──────────────────────
      // users/{uid}/library/{bookSlug}: {title, author, cover_url, isbn,
      //                                  google_id, added_at, page_count}
      match /library/{bookSlug} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    // ── Comments (pre-moderated) ─────────────────────────────
    // books/{bookSlug}/comments/{commentId}:
    //   {uid, name, text, createdAt, approved}
    match /books/{bookSlug}/comments/{commentId} {
      // Public may read ONLY approved comments. Queries MUST include
      // where("approved", "==", true) or they will be denied wholesale.
      // Authors can read their own pending comments; admin reads all.
      allow read: if resource.data.approved == true
        || (signedIn() && resource.data.uid == request.auth.uid)
        || isAdmin();

      // Anyone signed in WITH A VERIFIED EMAIL may create — but ALWAYS
      // unapproved, always as themselves, with hard caps the client cannot
      // bypass. Google sign-ins are email_verified by Google; email/password
      // accounts must click the confirmation link first (see the account
      // page's verification notice + resend button).
      allow create: if signedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 2
        && request.resource.data.text.size() <= 4000
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ["uid", "name", "text", "createdAt", "approved"]);

      // Approval (or any edit) is admin-only.
      allow update: if isAdmin();

      // Authors may retract their own comment; admin may delete any.
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);

      // Likes on a comment — doc id == liker uid → one like per user per
      // comment. Public read for the COUNT; the doc carries only a timestamp
      // (no uid field, so it's never mistaken for a favorites-"likes" doc by
      // the /account collection-group query, which filters where uid==me).
      match /likes/{uid} {
        allow read: if true;
        allow create: if signedIn() && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(["createdAt"])
          && request.resource.data.createdAt == request.time;
        allow delete: if signedIn() && request.auth.uid == uid;
        allow update: if false;
      }
    }

    // ── Recommendation votes (v1) ────────────────────────────
    // books/{bookSlug}/recs/{uid}: {createdAt}
    // Doc id == voter uid → structurally one vote per user per book.
    // Public read so COUNT aggregation queries work for every visitor;
    // the doc carries nothing but a timestamp.
    match /books/{bookSlug}/recs/{uid} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(["createdAt"])
        && request.resource.data.createdAt == request.time;
      // un-recommend; admin may also remove any vote (moderation/cleanup)
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow update: if false;
    }

    // ── Reader recommendations (pre-moderated) ───────────────
    // books/{bookSlug}/reader_recs/{recId}:
    //   {uid, name, rec_title, rec_author, rec_cover, reason, createdAt, approved}
    // A reader recommends ANOTHER book as similar to bookSlug, with a
    // reason. Same pre-moderation contract as comments: created
    // approved=false, publicly readable only once an admin approves; the
    // recommended book's title/author/cover are captured from the /search
    // picker (a real catalog book, not free text). Text content → the
    // email_verified gate applies.
    match /books/{bookSlug}/reader_recs/{recId} {
      allow read: if resource.data.approved == true
        || (signedIn() && resource.data.uid == request.auth.uid)
        || isAdmin();
      allow create: if signedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false
        && request.resource.data.rec_title is string
        && request.resource.data.rec_title.size() >= 1
        && request.resource.data.rec_title.size() <= 200
        && request.resource.data.rec_author is string
        && request.resource.data.rec_author.size() <= 200
        && request.resource.data.rec_cover is string
        && request.resource.data.rec_cover.size() <= 500
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 2
        && request.resource.data.reason.size() <= 600
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ["uid", "name", "rec_title", "rec_author", "rec_cover",
              "reason", "createdAt", "approved"]);
      allow update: if isAdmin();  // approve
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // ── Reader star ratings (1-5, one per user per book) ─────
    // books/{bookSlug}/ratings/{uid}: {stars, updatedAt}
    // Doc id == rater uid → structurally one rating per user per book;
    // update allowed so a reader can change their mind. Public read so
    // COUNT aggregations work for every visitor — a rating carries no
    // PII. Not gated on email_verified (same decision as likes/recs:
    // low-stakes signals, only text content needs the verified gate).
    match /books/{bookSlug}/ratings/{uid} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(["stars", "updatedAt"])
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.updatedAt == request.time;
      // clear my rating; admin may also remove any rating (moderation/cleanup)
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // ── Character likes (favorite a character) ───────────────
    // characters/{charSlug}/likes/{uid}:
    //   {createdAt, uid, name?, image_url?, book_title?}
    // Doc id == liker uid → one like per user per character (identity is
    // the character's canonical slug, shared across every book they appear
    // in). uid is ALSO a field so the owner can list their favorites via a
    // collection-group query on /account/. The optional display fields
    // (name/image/book) are snapshotted at like-time so the account page
    // can render real character cards without extra lookups.
    match /characters/{charSlug}/likes/{uid} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(
             ["createdAt", "uid", "name", "image_url", "book_title"])
        && request.resource.data.createdAt == request.time
        && (!("name" in request.resource.data)
            || (request.resource.data.name is string
                && request.resource.data.name.size() <= 80))
        && (!("image_url" in request.resource.data)
            || (request.resource.data.image_url is string
                && request.resource.data.image_url.size() <= 500))
        && (!("book_title" in request.resource.data)
            || (request.resource.data.book_title is string
                && request.resource.data.book_title.size() <= 200));
      allow delete: if signedIn() && request.auth.uid == uid;
      allow update: if false;
    }

    // ── Author likes (favorite an author) ────────────────────
    // authors/{authorSlug}/likes/{uid}: {createdAt, uid, name?}
    // Same one-like-per-user shape as character likes.
    match /authors/{authorSlug}/likes/{uid} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(["createdAt", "uid", "name"])
        && request.resource.data.createdAt == request.time
        && (!("name" in request.resource.data)
            || (request.resource.data.name is string
                && request.resource.data.name.size() <= 80));
      allow delete: if signedIn() && request.auth.uid == uid;
      allow update: if false;
    }

    // ── Author reviews (pre-moderated, same contract as book comments) ──
    // authors/{authorSlug}/comments/{commentId}:
    //   {uid, name, text, createdAt, approved}
    // The admin moderation page's collectionGroup("comments") query picks
    // these up automatically alongside book comments.
    match /authors/{authorSlug}/comments/{commentId} {
      allow read: if resource.data.approved == true
        || (signedIn() && resource.data.uid == request.auth.uid)
        || isAdmin();
      allow create: if signedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 2
        && request.resource.data.text.size() <= 4000
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ["uid", "name", "text", "createdAt", "approved"]);
      allow update: if isAdmin();
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);

      // Likes on an author review — same contract as book-comment likes.
      match /likes/{uid} {
        allow read: if true;
        allow create: if signedIn() && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(["createdAt"])
          && request.resource.data.createdAt == request.time;
        allow delete: if signedIn() && request.auth.uid == uid;
        allow update: if false;
      }
    }

    // Collection-group reads. Group queries are only authorized by
    // group-scoped matches like these:
    //  - admin: all comments (the /admin/comments/ moderation page)
    //  - owner: their own comments and likes (the /account/ page's
    //    "my comments" / "my favorite characters" lists — queries MUST
    //    filter where("uid","==",me) or they're denied wholesale)
    match /{path=**}/comments/{commentId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }
    match /{path=**}/likes/{likeId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
    }
    // reader_recs group query — admin moderates all pending; owner may list
    // their own (both MUST filter, e.g. where("approved","==",false) for
    // admin or where("uid","==",me) for owner, or they're denied wholesale).
    match /{path=**}/reader_recs/{recId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
