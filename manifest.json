---
# layout: null — the site-wide default layout would wrap this JSON in HTML.
layout: null
permalink: /manifest.json
---
{
  "name": "BookHub — Read less. Understand more.",
  "short_name": "BookHub",
  "description": "{{ site.description }}",
  "start_url": "{{ '/' | relative_url }}",
  "scope": "{{ '/' | relative_url }}",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#171717",
  "icons": [
    {
      "src": "{{ '/assets/icons/icon-192.png' | relative_url }}",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "{{ '/assets/icons/icon-512.png' | relative_url }}",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "{{ '/assets/icons/icon-512-maskable.png' | relative_url }}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
